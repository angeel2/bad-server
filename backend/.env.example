PORT=3000

# Подключение к MongoDB
# Для локальной разработки:
DB_ADDRESS=mongodb://127.0.0.1:27017/weblarek?authSource=admin
# Для Docker:
# DB_ADDRESS=mongodb://root:example@mongo:27017/weblarek?authSource=admin

UPLOAD_PATH=images
UPLOAD_PATH_TEMP=temp

# CORS разрешённые источники
# Для локальной разработки:
ORIGIN_ALLOW=http://localhost:5173
# Для Docker:
# ORIGIN_ALLOW=http://localhost

# Токены (для продакшена использовать короткие сроки)
AUTH_REFRESH_TOKEN_EXPIRY=7d
AUTH_ACCESS_TOKEN_EXPIRY=15m